{
  "name": "korea-mice-safety-agent",
  "version": "1.0.3",
  "description": "Korean MICE site-operation safety MCP agent with law, venue, hazard, duty, and checklist ontology packs.",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "korea-mice-safety-agent": "build/cli.js"
  },
  "files": [
    "build/*.js",
    "build/*.d.ts",
    "build/config/",
    "build/lib/",
    "build/ontology/",
    "build/tools/",
    "build/web/",
    "data/markdown/legal/",
    "data/markdown/public/",
    "data/markdown/worker-safety/",
    "data/public/",
    "data/scenarios/",
    "data/snapshots/ontology-baseline.json",
    "data/ontology-diff-report.json",
    "data/source-audit-report.json",
    "data/venue-corpus-audit-report.json",
    "data/venue-pdf-manifest.json",
    "docs/",
    "NOTICE.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"import('fs').then(fs=>fs.chmodSync('build/cli.js',0o755))\"",
    "start": "node build/index.js",
    "mcp:start": "node build/cli.js serve",
    "web": "node build/cli.js web",
    "tools": "node build/cli.js tools",
    "call": "node build/cli.js call",
    "sync:venue-pdfs": "node scripts/sync-venue-pdfs.mjs",
    "build:venue-index": "node scripts/build-venue-facility-index.mjs",
    "build:public-venue-summaries": "node scripts/generate-public-venue-summaries.mjs",
    "build:kopis-directory": "node build/cli.js build-venue-directory",
    "validate:venue-corpus": "node scripts/validate-venue-corpus.mjs",
    "audit:deps": "npm audit --omit=dev --audit-level=high",
    "audit:package-safety": "node scripts/audit-package-safety.mjs && npm run audit:deps",
    "prepublishOnly": "npm run audit:package-safety",
    "apply:freshness-policy": "node scripts/apply-source-freshness-policy.mjs",
    "audit:freshness": "node scripts/audit-source-freshness.mjs",
    "verify:venue-sources": "node scripts/verify-venue-source-links.mjs",
    "collect:local-ordinances": "node scripts/collect-local-ordinances.mjs",
    "verify:priority-ordinances": "node scripts/verify-priority-local-ordinance-articles.mjs",
    "refine:local-ordinances": "node scripts/refine-local-ordinance-pack.mjs",
    "audit:sources": "node scripts/generate-source-audit.mjs",
    "snapshot:ontology": "node scripts/generate-ontology-diff.mjs --write-baseline",
    "diff:ontology": "node scripts/generate-ontology-diff.mjs",
    "validate:scenarios": "node scripts/validate-scenarios.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "keywords": [
    "mcp",
    "mice",
    "event-safety",
    "korea",
    "venue-safety",
    "crowd-management",
    "ontology",
    "korean-law"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "docx": "^9.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.7.2"
  }
}
