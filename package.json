{
  "name": "event-safety-check-mcp",
  "version": "0.1.0",
  "description": "Event Safety Check(행사안전 체크), an offline Korean event safety MCP server for laws, venue rules, hazards, and checklists.",
  "type": "module",
  "main": "build/server/main.js",
  "files": [
    "build/",
    "README.md",
    "NOTICE.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "bun build/server/main.js",
    "dev": "bun src/server/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "mcp",
    "event-safety",
    "korea",
    "venue-safety",
    "crowd-management",
    "korean-law"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "docx": "^9.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.7.2"
  }
}
